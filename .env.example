# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here
GUILD_ID=your_test_guild_id_here

# Football Data API (https://www.football-data.org/client/register)
FOOTBALL_API_KEY=your_football_data_api_key_here

# PostgreSQL (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Bot Configuration
NOTIFICATION_CHANNEL_ID=your_channel_id_here
COMPETITION_CODE=WC

# AI Provider Selection (groq or openrouter)
# Default: groq (fastest, 30 RPM free, no credit card needed)
AI_PROVIDER=groq

# Groq API (https://console.groq.com)
# Free tier: 30 requests/min, no credit card needed
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API (https://openrouter.ai)
AI_API_KEY=your_openrouter_api_key_here

# Health Check
PORT=3000
