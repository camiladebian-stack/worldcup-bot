# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here
GUILD_ID=your_test_guild_id_here

# Football Data API (https://www.football-data.org/client/register)
FOOTBALL_API_KEY=your_football_data_api_key_here

# PostgreSQL (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Bot Configuration
NOTIFICATION_CHANNEL_ID=your_channel_id_here
COMPETITION_CODE=WC

# AI Provider Selection (gemini or openrouter)
AI_PROVIDER=gemini

# Google Gemini API (https://aistudio.google.com/apikey)
# Free tier: 1,500 requests/day, no credit card needed
GEMINI_API_KEY=your_google_gemini_api_key_here

# OpenRouter API (fallback provider - https://openrouter.ai)
AI_API_KEY=your_openrouter_api_key_here

# Health Check
PORT=3000
